        <visual name="leg_r_vis"><pose>0.46 0 0.375 0 0 0</pose>
          <geometry><box><size>0.04 0.50 0.75</size></box></geometry>
          <material><ambient>0.48 0.30 0.12 1</ambient><diffuse>0.48 0.30 0.12 1</diffuse></material>
