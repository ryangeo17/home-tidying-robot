    <!-- ============================================================ -->
    <!-- PICKUP OBJECTS                                               -->
    <!-- All: static=false, physically complete (mass + inertia +    -->
    <!-- collision + friction + visual), on the floor (z=half height)-->
    <!-- None placed inside the doorway (y=[-1,1] at x=0)           -->
    <!--                                                              -->
    <!-- Inertia for solid box: I = 1/12 * m * (a^2 + b^2)          -->
    <!-- Inertia for solid cylinder: Ixx=Iyy=1/12*m*(3r^2+h^2),     -->
    <!--                             Izz=1/2*m*r^2                   -->
    <!-- ============================================================ -->

    <!-- Object 1: red block, room 1 near centre -->
    <model name="pickup_block_red">
      <static>false</static>
      <pose>-2.0 -2.0 0.05 0 0 0.3</pose>
      <link name="link">
        <inertial>
          <mass>0.10</mass>
          <!-- 1/12*0.1*(0.1^2+0.1^2) = 0.000167 each, Izz same -->
          <inertia><ixx>0.000167</ixx><iyy>0.000167</iyy><izz>0.000167</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col">
          <geometry><box><size>0.10 0.10 0.10</size></box></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact><ode><kp>100000</kp><kd>10</kd></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.10 0.10 0.10</size></box></geometry>
          <material><ambient>0.80 0.10 0.10 1</ambient><diffuse>0.90 0.10 0.10 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Object 2: blue cylinder, room 1 near sofa -->
    <model name="pickup_cylinder_blue">
      <static>false</static>
      <pose>-1.5 2.8 0.06 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.15</mass>
          <!-- r=0.04 h=0.12: Ixx=Iyy=1/12*0.15*(3*0.0016+0.0144)=0.000225 Izz=0.5*0.15*0.0016=0.00012 -->
          <inertia><ixx>0.000240</ixx><iyy>0.000240</iyy><izz>0.000120</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact><ode><kp>100000</kp><kd>10</kd></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.10 0.10 0.85 1</ambient><diffuse>0.10 0.10 0.90 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Object 3: yellow block, room 1 — away from doorway -->
    <model name="pickup_block_yellow">
      <static>false</static>
      <pose>-1.5 -1.2 0.04 0 0 1.1</pose>
      <link name="link">
        <inertial>
          <mass>0.08</mass>
          <!-- 0.08x0.08x0.08 box: 1/12*0.08*(0.0064+0.0064)=0.0000853 -->
          <inertia><ixx>0.0000853</ixx><iyy>0.0000853</iyy><izz>0.0000853</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col">
          <geometry><box><size>0.08 0.08 0.08</size></box></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact><ode><kp>100000</kp><kd>10</kd></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.08 0.08 0.08</size></box></geometry>
          <material><ambient>0.92 0.82 0.08 1</ambient><diffuse>0.92 0.82 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Object 4: orange cylinder, room 2 open area -->
    <model name="pickup_cylinder_orange">
      <static>false</static>
      <pose>2.0 -1.5 0.06 0 0 0</pose>
      <link name="link">
        <inertial>
          <mass>0.12</mass>
          <!-- r=0.04 h=0.12: Ixx=Iyy=1/12*0.12*(0.0048+0.0144)=0.000192 Izz=0.5*0.12*0.0016=0.000096 -->
          <inertia><ixx>0.000192</ixx><iyy>0.000192</iyy><izz>0.000096</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col">
          <geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact><ode><kp>100000</kp><kd>10</kd></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><cylinder><radius>0.04</radius><length>0.12</length></cylinder></geometry>
          <material><ambient>0.92 0.50 0.08 1</ambient><diffuse>0.92 0.50 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- Object 5: purple block, room 2 near desk -->
    <model name="pickup_block_purple">
      <static>false</static>
      <pose>3.0 -2.8 0.05 0 0 0.5</pose>
      <link name="link">
        <inertial>
          <mass>0.10</mass>
          <inertia><ixx>0.000167</ixx><iyy>0.000167</iyy><izz>0.000167</izz>
                   <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia>
        </inertial>
        <collision name="col">
          <geometry><box><size>0.10 0.10 0.10</size></box></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact><ode><kp>100000</kp><kd>10</kd></ode></contact>
          </surface>
        </collision>
        <visual name="vis">
          <geometry><box><size>0.10 0.10 0.10</size></box></geometry>
