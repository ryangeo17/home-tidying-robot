        </collision>
        <visual name="vis">
          <geometry><box><size>0.10 0.10 0.10</size></box></geometry>
          <material><ambient>0.10 0.72 0.20 1</ambient><diffuse>0.10 0.72 0.20 1</diffuse></material>
        </visual>
