<?xml version ="1.0"?>
<robot name="tidying_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <!-- Define materials -->
    <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1.0"/>
    </material>
    <material name="light_grey">
        <color rgba="0.7 0.7 0.7 1.0"/>
    </material>
    <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
    </material>
    <material name="black">
        <color rgba="0.05 0.05 0.05 1.0"/>
    </material>
    <material name="orange">
        <color rgba="0.9 0.5 0.1 1.0"/>
    </material>
    <material name="white">
        <color rgba="0.95 0.95 0.95 1.0"/>
    </material>
    <material name="cyan_glow">
        <color rgba="0.0 0.9 0.95 1.0"/>
    </material>
    <material name="red">
        <color rgba="0.8 0.1 0.1 1.0"/>
    </material>


    <!-- Base Link -->
    <link name="base_link">
    <visual>
      <geometry>
        <box size="0.50 0.40 0.12"/>
      </geometry>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.50 0.40 0.12"/>
      </geometry>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="12.0"/>
      <origin xyz="0 0 0.06" rpy="0 0 0"/>
      <!-- Ixx=1/12*m*(y^2+z^2), Iyy=1/12*m*(x^2+z^2), Izz=1/12*m*(x^2+y^2) -->
      <inertia ixx="0.1744" iyy="0.2644" izz="0.4100"
               ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>

    <!-- Dummy base_footprint for nav stack compatibility -->
    <link name="base_footprint"/>
    <joint name="base_footprint_joint" type="fixed">
        <parent link="base_footprint"/>
        <child link="base_link"/>
        <origin xyz="0 0 0.075" rpy="0 0 0"/>
    </joint>

    <!-- ==Wheels== -->
    <!-- Front Left Wheel -->
    <link name="front_left_wheel">
        <visual>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <material name="black"/>
        </visual>
        <collision>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <surface>
        <friction>
            <ode>
            <mu>1.0</mu>
            <mu2>0.8</mu2>
            <kp>1000000</kp>
            <kd>100</kd>
            </ode>
        </friction>
        </surface>
        </collision>
        <inertial>
        <mass value="0.8"/>
        <inertia ixx="0.001231" iyy="0.001231" izz="0.002250"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>
    <joint name="front_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="front_left_wheel"/>
        <!-- Wheel center at x=+0.15 (front), y=+0.22 (left), z=0 (ground contact) -->
        <origin xyz="0.15 0.22 0.0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <!-- Front-Right Wheel -->
    <link name="front_right_wheel">
        <visual>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <material name="black"/>
        </visual>
        <collision>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <surface>
        <friction>
            <ode>
            <mu>1.0</mu>
            <mu2>0.8</mu2>
            <kp>1000000</kp>
            <kd>100</kd>
            </ode>
        </friction>
        </surface>
        </collision>
        <inertial>
        <mass value="0.8"/>
        <inertia ixx="0.001231" iyy="0.001231" izz="0.002250"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>
    <joint name="front_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="front_right_wheel"/>
        <origin xyz="0.15 -0.22 0.0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <!-- Rear-Left Wheel -->
    <link name="rear_left_wheel">
        <visual>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <material name="black"/>
        </visual>
        <collision>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <surface>
        <friction>
            <ode>
            <mu>1.0</mu>
            <mu2>0.8</mu2>
            <kp>1000000</kp>
            <kd>100</kd>
            </ode>
        </friction>
        </surface>
        </collision>
        <inertial>
        <mass value="0.8"/>
        <inertia ixx="0.001231" iyy="0.001231" izz="0.002250"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>
    <joint name="rear_left_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rear_left_wheel"/>
        <origin xyz="-0.15 0.22 0.0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <!-- Rear-Right Wheel -->
    <link name="rear_right_wheel">
        <visual>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <material name="black"/>
        </visual>
        <collision>
        <geometry>
            <cylinder radius="0.075" length="0.04"/>
        </geometry>
        <surface>
        <friction>
        <ode>
            <mu>1.0</mu>
            <mu2>0.8</mu2>
            <kp>1000000</kp>
            <kd>100</kd>
        </ode>
        </friction>
        </surface>
        </collision>
        <inertial>
        <mass value="0.8"/>
        <inertia ixx="0.001231" iyy="0.001231" izz="0.002250"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>
    <joint name="rear_right_wheel_joint" type="continuous">
        <parent link="base_link"/>
        <child link="rear_right_wheel"/>
        <origin xyz="-0.15 -0.22 0.0" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.1" friction="0.05"/>
    </joint>

    <!--=======TORSO(vertical column: 0.20 x 0.18 x 0.55, Sits on top of base. Mass ~5 kg=====-->
    <link name="torso_link">
    <visual>
      <geometry>
        <box size="0.20 0.18 0.55"/>
      </geometry>
      <origin xyz="0 0 0.275" rpy="0 0 0"/>
      <material name="light_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.20 0.18 0.55"/>
      </geometry>
      <origin xyz="0 0 0.275" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 0.275" rpy="0 0 0"/>
      <!-- 1/12*5*(0.18^2+0.55^2)=0.1394, 1/12*5*(0.20^2+0.55^2)=0.1427, 1/12*5*(0.20^2+0.18^2)=0.0302 -->
      <inertia ixx="0.1394" iyy="0.1427" izz="0.0302"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="torso_joint" type="fixed">
        <parent link="base_link"/>
        <child link="torso_link"/>
        <origin xyz="0 0 0.12" rpy="0 0 0"/>
    </joint>
    <!--===HEAD / LED FACE PANEL===-->
    <link name="head_link">
    <visual>
      <geometry>
        <box size="0.02 0.16 0.12"/>
      </geometry>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <material name="cyan_glow"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.02 0.16 0.12"/>
      </geometry>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <origin xyz="0 0 0.0" rpy="0 0 0"/>
      <inertia ixx="0.001010" iyy="0.000370" izz="0.000650"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="head_joint" type="fixed">
        <parent link="torso_link"/>
        <child link="head_link"/>
        <!-- Mounted on the front face of torso, at the top -->
        <origin xyz="0.11 0 0.50" rpy="0 0 0"/>
    </joint>


    <!-- ===RIGHT ARM (3 DOF) === -->
    <!-- Shoulder link -->
  <link name="right_shoulder_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.000207" iyy="0.000207" izz="0.000368"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="right_shoulder_joint" type="revolute">
    <parent link="torso_link"/>
    <child link="right_shoulder_link"/>
    <!-- Shoulder on right side, near top of torso -->
    <origin xyz="0.0 -0.12 0.48" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.356" upper="2.356" effort="30.0" velocity="1.5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- Upper arm -->
  <link name="right_upper_arm_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.28"/>
      </geometry>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.28"/>
      </geometry>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <!-- cylinder: Ixx=Iyy=1/12*m*(3r^2+h^2), Izz=1/2*m*r^2 -->
      <inertia ixx="0.006758" iyy="0.006758" izz="0.000450"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
  <joint name="right_upper_arm_joint" type="fixed">
    <parent link="right_shoulder_link"/>
    <child link="right_upper_arm_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Elbow -->
  <link name="right_elbow_link">
    <visual>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.000196" iyy="0.000196" izz="0.000196"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>

    <joint name="right_elbow_joint" type="revolute">
        <parent link="right_upper_arm_link"/>
        <child link="right_elbow_link"/>
        <origin xyz="0 0 -0.28" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.356" upper="0.0" effort="20.0" velocity="1.5"/>
        <dynamics damping="0.4" friction="0.08"/>
    </joint>

    <!-- Forearm -->
    <link name="right_forearm_link">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.26"/>
      </geometry>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.26"/>
      </geometry>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/>
      <inertia ixx="0.004011" iyy="0.004011" izz="0.000219"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="right_forearm_joint" type="fixed">
        <parent link="right_elbow_link"/>
        <child link="right_forearm_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Wrist -->
    <link name="right_wrist_link">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.03"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0000194" iyy="0.0000194" izz="0.0000625"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="right_wrist_joint" type="revolute">
        <parent link="right_forearm_link"/>
        <child link="right_wrist_link"/>
        <origin xyz="0 0 -0.26" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.571" upper="1.571" effort="10.0" velocity="2.0"/>
        <dynamics damping="0.3" friction="0.05"/>
    </joint>

    <!-- Gripper (parallel-jaw style, modeled as two finger pads + a palm) -->
    <!-- Palm -->
    <link name="right_gripper_palm">
    <visual>
      <geometry>
        <box size="0.06 0.08 0.02"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.08 0.02"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.15"/>
      <inertia ixx="0.0000853" iyy="0.0000503" izz="0.000125"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="right_gripper_palm_joint" type="fixed">
        <parent link="right_wrist_link"/>
        <child link="right_gripper_palm"/>
        <origin xyz="0 0 -0.025" rpy="0 0 0"/>
    </joint>

    <!-- Left Finger -->
    <link name="right_gripper_left_finger">
    <visual>
      <geometry>
        <box size="0.06 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <inertia ixx="0.0000175" iyy="0.0000154" izz="0.0000042"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="right_gripper_left_finger_joint" type="prismatic">
        <parent link="right_gripper_palm"/>
        <child link="right_gripper_left_finger"/>
        <origin xyz="0 0.035 -0.01" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="0.0" upper="0.02" effort="5.0" velocity="0.5"/>
        <dynamics damping="0.2" friction="0.05"/>
    </joint>

    <!-- Right Finger -->
    <link name="right_gripper_right_finger">
    <visual>
      <geometry>
        <box size="0.06 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <material name="red"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.01 0.06"/>
      </geometry>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <origin xyz="0 0 -0.03" rpy="0 0 0"/>
      <inertia ixx="0.0000175" iyy="0.0000154" izz="0.0000042"
               ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>
    <joint name="right_gripper_right_finger_joint" type="prismatic">
        <parent link="right_gripper_palm"/>
        <child link="right_gripper_right_finger"/>
        <origin xyz="0 -0.035 -0.01" rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="0.0" upper="0.02" effort="5.0" velocity="0.5"/>
        <dynamics damping="0.2" friction="0.05"/>
    </joint>

    <!--  LEFT ARM (cosmetic / static — mirrors right arm visually)    -->
    <link name="left_shoulder_link">
    <visual>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.035" length="0.06"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.6"/>
      <inertia ixx="0.000207" iyy="0.000207" izz="0.000368"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="left_shoulder_joint" type="fixed">
        <parent link="torso_link"/>
        <child link="left_shoulder_link"/>
        <origin xyz="0.0 0.12 0.48" rpy="0 0 0"/>
    </joint>

    <link name="left_upper_arm_link">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.28"/>
      </geometry>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.28"/>
      </geometry>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1.0"/>
      <origin xyz="0 0 -0.14" rpy="0 0 0"/>
      <inertia ixx="0.006758" iyy="0.006758" izz="0.000450"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="left_upper_arm_joint" type="fixed">
        <parent link="left_shoulder_link"/>
        <child link="left_upper_arm_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="left_elbow_link">
    <visual>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <geometry>
        <sphere radius="0.035"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.000196" iyy="0.000196" izz="0.000196"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="left_elbow_joint" type="fixed">
        <parent link="left_upper_arm_link"/>
        <child link="left_elbow_link"/>
        <origin xyz="0 0 -0.28" rpy="0 -1.5708 0"/>
    </joint>

    <link name="left_forearm_link">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.26"/>
      </geometry>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/>
      <material name="orange"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.025" length="0.26"/>
      </geometry>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.7"/>
      <origin xyz="0 0 -0.13" rpy="0 0 0"/>
      <inertia ixx="0.004011" iyy="0.004011" izz="0.000219"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="left_forearm_joint" type="fixed">
        <parent link="left_elbow_link"/>
        <child link="left_forearm_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="left_hand_link">
    <visual>
      <geometry>
        <box size="0.06 0.08 0.04"/>
      </geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.06 0.08 0.04"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.000107" iyy="0.0000867" izz="0.000133"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="left_hand_joint" type="fixed">
        <parent link="left_forearm_link"/>
        <child link="left_hand_link"/>
        <origin xyz="0 0 -0.28" rpy="0 0 0"/>
    </joint>
    <!--  CAMERA — mounted on front of torso (not head)-->
    <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <geometry>
        <box size="0.03 0.06 0.03"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0000375" iyy="0.0000150" izz="0.0000375"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
    </link>
    <joint name="camera_joint" type="fixed">
        <parent link="torso_link"/>
        <child link="camera_link"/>
        <!-- Front face of torso, roughly mid-height -->
        <origin xyz="0.115 0 0.35" rpy="0 0 0"/>
    </joint>

    <!-- Camera optical frame (ROS convention: z forward, x right, y down) -->
    <link name="camera_optical_frame"/>
    <joint name="camera_optical_joint" type="fixed">
        <parent link="camera_link"/>
        <child link="camera_optical_frame"/>
        <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>

    <!--  LIDAR — 2D scanning LiDAR on top of base, front              -->

    <link name="lidar_link">
        <visual>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
        <material name="black"/>
        </visual>
        <collision>
        <geometry>
            <cylinder radius="0.04" length="0.04"/>
        </geometry>
        </collision>
        <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.0000453" iyy="0.0000453" izz="0.000160"
                ixy="0" ixz="0" iyz="0"/>
        </inertial>
    </link>
    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <!-- Mounted on top of the base plate, front-center -->
        <origin xyz="0.18 0 0.14" rpy="0 0 0"/>
    </joint>
    <!-- ============================================================ -->
    <!--  GAZEBO PLUGINS  (Gazebo Harmonic / gz-sim)                   -->
    <!-- ============================================================ -->
    <gazebo>
        <!-- Skid-steer drive controller -->
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>front_left_wheel_joint</left_joint>
            <left_joint>rear_left_wheel_joint</left_joint>
            <right_joint>front_right_wheel_joint</right_joint>
            <right_joint>rear_right_wheel_joint</right_joint>
            <wheel_separation>0.44</wheel_separation>
            <wheel_radius>0.075</wheel_radius>
            <max_linear_acceleration>1.0</max_linear_acceleration>
            <max_angular_acceleration>2.0</max_angular_acceleration>
            <topic>/cmd_vel</topic>
            <odom_topic>/odom</odom_topic>
            <tf_topic>/tf</tf_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
            <odom_publish_frequency>50</odom_publish_frequency>
        </plugin>
        <!-- Joint position controller for arm -->
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>right_shoulder_joint</joint_name>
            <topic>/right_shoulder_joint/cmd</topic>
            <p_gain>30.0</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>5.0</d_gain>
        </plugin>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>right_elbow_joint</joint_name>
            <topic>/right_elbow_joint/cmd</topic>
            <p_gain>20.0</p_gain>
            <i_gain>0.1</i_gain>
            <d_gain>3.0</d_gain>
        </plugin>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>right_wrist_joint</joint_name>
            <topic>/right_wrist_joint/cmd</topic>
            <p_gain>10.0</p_gain>
            <i_gain>0.05</i_gain>
            <d_gain>2.0</d_gain>
        </plugin>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>right_gripper_left_finger_joint</joint_name>
            <topic>/right_gripper_left_finger_joint/cmd</topic>
            <p_gain>5.0</p_gain>
            <i_gain>0.01</i_gain>
            <d_gain>1.0</d_gain>
        </plugin>
        <plugin filename="gz-sim-joint-position-controller-system"
                name="gz::sim::systems::JointPositionController">
            <joint_name>right_gripper_right_finger_joint</joint_name>
            <topic>/right_gripper_right_finger_joint/cmd</topic>
            <p_gain>5.0</p_gain>
            <i_gain>0.01</i_gain>
            <d_gain>1.0</d_gain>
        </plugin>

        <!-- Joint state publisher — feeds robot_state_publisher via bridge -->
        <plugin filename="gz-sim-joint-state-publisher-system"
                name="gz::sim::systems::JointStatePublisher">
            <joint_name>front_left_wheel_joint</joint_name>
            <joint_name>front_right_wheel_joint</joint_name>
            <joint_name>rear_left_wheel_joint</joint_name>
            <joint_name>rear_right_wheel_joint</joint_name>
            <joint_name>right_shoulder_joint</joint_name>
            <joint_name>right_elbow_joint</joint_name>
            <joint_name>right_wrist_joint</joint_name>
            <joint_name>right_gripper_left_finger_joint</joint_name>
            <joint_name>right_gripper_right_finger_joint</joint_name>
            <topic>/joint_states</topic>
        </plugin>

    </gazebo>
    <!-- 2D LiDAR sensor (Gazebo Harmonic) -->
    <gazebo reference="lidar_link">
        <sensor name="lidar" type="gpu_lidar">
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <lidar>
            <scan>
            <horizontal>
                <samples>360</samples>
                <resolution>1</resolution>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
            </horizontal>
            <vertical>
                <samples>1</samples>
                <resolution>1</resolution>
                <min_angle>0</min_angle>
                <max_angle>0</max_angle>
            </vertical>
            </scan>
            <range>
            <min>0.12</min>
            <max>10.0</max>
            <resolution>0.01</resolution>
            </range>
        </lidar>
        <topic>/scan</topic>
        <gz_frame_id>lidar_link</gz_frame_id>
        </sensor>
    </gazebo>
    <!-- RGB Camera sensor (Gazebo Harmonic) -->
    <gazebo reference="camera_link">
        <sensor name="camera" type="camera">
            <always_on>true</always_on>
            <update_rate>15</update_rate>
            <camera>
                <horizontal_fov>1.3962</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.05</near>
                    <far>15.0</far>
                </clip>
            </camera>
            <topic>/camera/image_raw</topic>
            <gz_frame_id>camera_link</gz_frame_id>
        </sensor>
    </gazebo>

</robot>

  
